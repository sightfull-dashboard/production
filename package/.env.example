NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
DATABASE_PROVIDER=supabase

# Required in production
SESSION_SECRET=replace-with-a-long-random-secret-value
SESSION_SQLITE_PATH=sightfull-sessions.db
SESSION_STORE_DRIVER=supabase
SESSION_MAX_AGE_MS=86400000
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false
TRUST_PROXY=false
BODY_LIMIT_MB=25
DIRECT_UPLOAD_LIMIT_MB=100
BACKGROUND_WORKER_POLL_INTERVAL_MS=3000
BACKGROUND_WORKER_MAX_ATTEMPTS=4
BACKGROUND_WORKER_RETENTION_HOURS=168
PAYROLL_EMAIL_ASYNC=true
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_STORE_DRIVER=supabase
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
FILE_DOWNLOAD_URL_TTL_SECONDS=900

# Configure at least one production super admin
SUPERADMIN_EMAILS=admin@example.com
# Optional first-run bootstrap account (must be supplied together)
BOOTSTRAP_SUPERADMIN_EMAIL=
BOOTSTRAP_SUPERADMIN_PASSWORD=

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

SUPABASE_BUCKET_CLIENT_ASSETS=client-assets
SUPABASE_BUCKET_EMPLOYEE_DOCUMENTS=employee-documents
SUPABASE_BUCKET_VAULT_FILES=vault-files
SUPABASE_BUCKET_PAYROLL_ATTACHMENTS=payroll-attachments

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Sightfull
SMTP_FROM_EMAIL=
